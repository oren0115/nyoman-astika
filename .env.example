
# MongoDB — Prisma requires the default database name in the URL path (after the host), before "?".
# Correct:   ...mongodb.net/portfolio?retryWrites=true&w=majority
# Wrong:     ...mongodb.net?retryWrites=...   (missing /portfolio or other DB name → P1013)
# Atlas: copy URI from Database → Connect → Drivers, then ensure "/yourDbName" appears before the query string.
DATABASE_URL="mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority"

# Generate one with: openssl rand -hex 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"


# Local
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudinary — https://cloudinary.com/console → Dashboard / API Keys
# Option A: single URL from the dashboard (Programmable Media → API Environment variable)
# CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# Option B: three variables
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
