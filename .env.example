
# Local PostgreSQL (no SSL needed)
DATABASE_URL="postgresql://username:password@localhost:5432/portfolio_db"

# Cloud Postgres TLS: leave unset for normal verification. If you see "self-signed certificate in certificate chain",
# prefer adding the provider CA via sslrootcert on DATABASE_URL. As a last resort only: DATABASE_SSL_REJECT_UNAUTHORIZED=false
# DATABASE_SSL_REJECT_UNAUTHORIZED=""

# Generate one with: openssl rand -hex 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"


# Local
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cloudinary (production / optional locally). Get keys from https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
